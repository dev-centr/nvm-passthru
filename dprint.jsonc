{
  "json": {},
  "markdown": {},
  "includes": [
    "**/*.{json,jsonc,md,mdx,ts,tsx,js,jsx}"
  ],
  "excludes": [
    "**/node_modules",
    "**/*-lock.json",
    "**/target"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.19.3.wasm",
    "https://plugins.dprint.dev/markdown-0.17.1.wasm"
  ]
}